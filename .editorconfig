root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.c]
indent_style = space
indent_size = 4

[*.h]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab

[*.yml]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
